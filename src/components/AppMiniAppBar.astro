---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="mini-app-bar">
  <div>
    <p class="mini-app-bar__label">Ansiversa • Premium Workspace</p>
    <h1>{title}</h1>
    {subtitle ? <p class="mini-app-bar__subtitle">{subtitle}</p> : null}
  </div>
</header>
