---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";

const title = "Meeting Minutes AI – Ansiversa";
const description = "Capture and structure meeting notes with a premium executive-ready workspace.";
---

<AppShell title={title} description={description}>
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-hero__content">
        <div class="av-kicker"><span>Career & Work · Ansiversa Mini App</span></div>
        <h1 class="av-gradient-text">Meeting Minutes AI</h1>
        <p>A structured workspace for professional meeting minutes and follow-through.</p>
      </div>
      <div class="av-cta-row">
        <AvButton href="/app">Open Workspace</AvButton>
      </div>
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="narrow">
      <AvCard>
        <h2>Built for clear, executive-ready documentation.</h2>
        <p>
          Capture meeting purpose, discussion, decisions, and action items in one calm workspace with a live structured preview.
        </p>
      </AvCard>
    </AvContainer>
  </section>
</AppShell>
